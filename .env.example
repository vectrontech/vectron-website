# Image generation (local only — not needed at build time; outputs are committed)
GEMINI_API_KEY=your_gemini_api_key_here
# Model override. Defaults to "gemini-3-pro-image-preview" (Nano Banana 2).
# Use "gemini-2.5-flash-image-preview" for the original Nano Banana.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Formspree — public site-level key. Safe to expose in client bundle.
# Create a form at https://formspree.io and paste the form ID (the string after /f/).
PUBLIC_FORMSPREE_ID=your_formspree_id_here
