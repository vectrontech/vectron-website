---
interface Props {
  value: string;
  label: string;
}
const { value, label } = Astro.props;
---

<div class="card p-6">
  <div class="chrome-text font-display text-4xl md:text-5xl font-semibold leading-none">
    {value}
  </div>
  <div class="mt-3 text-sm text-[color:var(--color-muted)]">{label}</div>
</div>
