---
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-[color:var(--color-chrome-rule)]">
  <div class="container-narrow py-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <div class="font-display text-sm tracking-[0.14em] uppercase text-[color:var(--color-chrome-ink)]">
        Vectron Technologies
      </div>
      <p class="mt-3 text-sm text-[color:var(--color-muted)] max-w-xs">
        Engineering-grade AI automation. Built by engineers, delivered to spec.
      </p>
    </div>

    <div>
      <div class="eyebrow">Services</div>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-[color:var(--color-muted)] hover:text-white transition-colors" href="/services/ai-automation-for-engineering-firms/">AI for engineering firms</a></li>
        <li><a class="text-[color:var(--color-muted)] hover:text-white transition-colors" href="/services/ai-automation-for-sales-agencies/">AI for sales agencies</a></li>
        <li><a class="text-[color:var(--color-muted)] hover:text-white transition-colors" href="/services/rf-electromagnetics/">RF / electromagnetics</a></li>
      </ul>
    </div>

    <div>
      <div class="eyebrow">Contact</div>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-[color:var(--color-muted)] hover:text-white transition-colors" href="/contact/">Start a conversation</a></li>
      </ul>
    </div>
  </div>

  <div class="rule-chrome"></div>

  <div class="container-narrow py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-[color:var(--color-chrome-dim)]">
    <div>© {year} Vectron Technologies. All rights reserved.</div>
    <div class="font-display tracking-[0.2em] uppercase">Engineered in the US</div>
  </div>
</footer>
