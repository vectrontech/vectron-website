---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import Section from "~/components/Section.astro";
import CTASection from "~/components/CTASection.astro";

const title = "Antenna Design and Electromagnetics Consulting | Vectron Technologies";
const description =
  "Senior antenna design and electromagnetics consulting. Link budget analysis, EMC and EMI investigations, HFSS, CST, and FEKO simulation review. Project or retainer engagements.";

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Antenna design and electromagnetics consulting",
  provider: {
    "@type": "ProfessionalService",
    name: "Vectron Technologies",
    url: "https://vectrontechnologies.com",
  },
  serviceType: "RF and electromagnetics engineering",
  description:
    "Antenna design and integration, link budget and propagation analysis, EMC and EMI investigations, and independent design or simulation review. Tools include HFSS, CST, FEKO, and ADS.",
  areaServed: { "@type": "Country", name: "United States" },
  url: "https://vectrontechnologies.com/services/rf-electromagnetics/",
};
---

<BaseLayout title={title} description={description} path="/services/rf-electromagnetics/" ogImage="/images/generated/rf-hero.png" serviceJsonLd={serviceJsonLd}>
  <Hero
    eyebrow="RF / Electromagnetics"
    title="Senior RF consulting,"
    titleAccent="from antenna to system."
    subtitle="Antenna design, link-budget analysis, EMC/EMI investigations, simulation review. For teams that need a senior engineer in the room, not a slide deck about one."
    image="/images/generated/rf-hero.png"
    imageAlt="Close-up visual of an RF front-end assembly with coaxial connectors and shielded enclosure."
    primaryCta={{ href: "/contact/", label: "Discuss a program" }}
    secondaryCta={{ href: "#capabilities", label: "Capabilities" }}
  />

  <Section
    eyebrow="Practice"
    title="What we work on"
    lede="Vectron's RF practice exists for teams that need real engineering: the kind that gets reviewed, tested, and put into hardware that ships. This page does not talk about AI on purpose. RF buyers need a credible engineer, not a technology pitch."
  />

  <Section
    id="capabilities"
    tone="muted"
    eyebrow="Capabilities"
    title="Where we contribute"
  >
    <div class="grid gap-6 md:grid-cols-2">
      <div class="card p-8">
        <div class="eyebrow">Antenna & front-end</div>
        <h3 class="mt-3 font-display text-xl text-white">Antenna design & integration</h3>
        <p class="mt-3 text-[color:var(--color-muted)]">
          Concept through measurement for printed, wire, and aperture antennas. Co-design with RF front-ends and host platforms. HFSS, CST, FEKO.
        </p>
      </div>
      <div class="card p-8">
        <div class="eyebrow">Link & propagation</div>
        <h3 class="mt-3 font-display text-xl text-white">Link budgets & propagation</h3>
        <p class="mt-3 text-[color:var(--color-muted)]">
          End-to-end link analysis from datasheets or measured components. Terrestrial, line-of-sight, and satellite links. Margin accounting that holds up to review.
        </p>
      </div>
      <div class="card p-8">
        <div class="eyebrow">EMC / EMI</div>
        <h3 class="mt-3 font-display text-xl text-white">EMC / EMI investigations</h3>
        <p class="mt-3 text-[color:var(--color-muted)]">
          Root-cause analysis on emissions and susceptibility failures. Design-for-EMC reviews. Mitigation that addresses the physics, not the symptom.
        </p>
      </div>
      <div class="card p-8">
        <div class="eyebrow">Review</div>
        <h3 class="mt-3 font-display text-xl text-white">Simulation & design review</h3>
        <p class="mt-3 text-[color:var(--color-muted)]">
          Independent review of your team's RF simulations, designs, and test plans. A senior set of eyes before a costly build commits.
        </p>
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Engagement"
    title="How we work"
  >
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="card p-8">
        <div class="chrome-text font-display text-3xl font-semibold">Project</div>
        <p class="mt-3 text-sm text-[color:var(--color-muted)]">Fixed-scope engagement (design, analysis, or investigation) with defined deliverables and review cadence.</p>
      </div>
      <div class="card p-8">
        <div class="chrome-text font-display text-3xl font-semibold">Retainer</div>
        <p class="mt-3 text-sm text-[color:var(--color-muted)]">Embedded senior engineer on a monthly cadence. Design reviews, trade studies, and technical direction.</p>
      </div>
      <div class="card p-8">
        <div class="chrome-text font-display text-3xl font-semibold">Advisory</div>
        <p class="mt-3 text-sm text-[color:var(--color-muted)]">Short-form consulting for specific technical questions. Hours-based, no minimum.</p>
      </div>
    </div>
  </Section>

  <CTASection
    eyebrow="Next step"
    title="Describe your problem."
    subtitle="A 30-minute technical conversation. If we're the right fit, we'll scope a proposal. If we're not, we'll point you toward someone who is."
  />
</BaseLayout>
