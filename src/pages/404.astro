---
import BaseLayout from "~/layouts/BaseLayout.astro";

const title = "Page not found | Vectron Technologies";
const description =
  "The page you were looking for does not exist. Head back to Vectron Technologies: AI automation, antenna design, and electromagnetics consulting.";
---

<BaseLayout title={title} description={description} path="/404/">
  <section class="relative pt-32 pb-24 md:pt-48 md:pb-32">
    <div class="absolute inset-0 bg-blueprint bg-blueprint-fade opacity-60 pointer-events-none" aria-hidden="true"></div>
    <div class="container-narrow relative text-center">
      <div class="eyebrow">Error 404</div>
      <h1 class="mt-5 font-display text-6xl md:text-8xl font-semibold leading-[0.98] uppercase tracking-[-0.01em]">
        <span class="chrome-text">Signal not found.</span>
      </h1>
      <p class="mt-6 max-w-xl mx-auto text-lg text-[color:var(--color-muted)] leading-relaxed">
        The page you were looking for is not here. It may have moved, or the link you followed is out of date.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn btn-primary">
          Back to home
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/contact/" class="btn btn-ghost">Contact us</a>
      </div>

      <div class="rule-chrome mt-20"></div>

      <div class="mt-12 grid gap-6 md:grid-cols-3 text-left max-w-3xl mx-auto">
        <a href="/services/ai-automation-for-engineering-firms/" class="card p-6 block">
          <div class="eyebrow">Services</div>
          <div class="mt-2 font-display text-white">AI for engineering firms</div>
        </a>
        <a href="/services/ai-automation-for-sales-agencies/" class="card p-6 block">
          <div class="eyebrow">Services</div>
          <div class="mt-2 font-display text-white">AI for sales agencies</div>
        </a>
        <a href="/services/rf-electromagnetics/" class="card p-6 block">
          <div class="eyebrow">Services</div>
          <div class="mt-2 font-display text-white">RF and electromagnetics</div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
