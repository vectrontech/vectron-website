---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ContactForm from "~/components/ContactForm.astro";

const title = "Contact — Vectron Technologies";
const description =
  "Start a conversation with Vectron Technologies. AI automation and RF engineering consulting. We reply within one business day.";
---

<BaseLayout title={title} description={description} path="/contact/">
  <section class="relative pt-24 md:pt-32 pb-10">
    <div class="absolute inset-0 bg-blueprint bg-blueprint-fade opacity-60 pointer-events-none" aria-hidden="true"></div>
    <div class="container-narrow relative">
      <div class="max-w-2xl">
        <div class="eyebrow">Contact</div>
        <h1 class="mt-5 font-display text-5xl md:text-6xl font-semibold leading-[1.02]">
          <span class="chrome-text">Let's talk.</span>
        </h1>
        <p class="mt-6 text-lg text-[color:var(--color-muted)] leading-relaxed">
          Tell us what you're working on and what you're trying to solve. We reply within one business day. If we're not the right fit, we'll tell you — and where possible we'll point you toward someone who is.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-24 md:pb-32">
    <div class="container-narrow grid gap-10 md:grid-cols-[2fr_1fr]">
      <div class="card p-8 md:p-10">
        <ContactForm />
      </div>

      <aside class="space-y-8">
        <div>
          <div class="eyebrow">Direct</div>
          <a href="mailto:info@vectrontechnologies.com" class="mt-3 block font-display text-lg text-white hover:text-[color:var(--color-accent)] transition-colors break-all">
            info@vectrontechnologies.com
          </a>
        </div>
        <div>
          <div class="eyebrow">What to include</div>
          <ul class="mt-3 space-y-2 text-sm text-[color:var(--color-muted)]">
            <li>— Company and role</li>
            <li>— One-paragraph problem statement</li>
            <li>— Timeline or constraints, if any</li>
          </ul>
        </div>
        <div>
          <div class="eyebrow">What happens next</div>
          <p class="mt-3 text-sm text-[color:var(--color-muted)] leading-relaxed">
            We read every inbound. If there's a fit, we'll propose a 30-minute call to scope the work. No decks, no sales motion — a direct technical conversation.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
